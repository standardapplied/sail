<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <groupId>ai.singlr</groupId>
    <artifactId>sail</artifactId>
    <version>0.13.80</version>
    <packaging>pom</packaging>

    <modules>
        <module>sail-core</module>
        <module>sail-harness</module>
        <module>sail-infra</module>
    </modules>

    <developers>
        <developer>
            <name>Standard Applied Intelligence Labs</name>
            <organization>Standard Applied Intelligence Labs</organization>
            <organizationUrl>https://github.com/singlr-ai/sing</organizationUrl>
        </developer>
    </developers>

    <properties>
        <picocli-version>4.7.7</picocli-version>
        <snakeyaml-engine-version>3.0.1</snakeyaml-engine-version>
        <junit-version>6.0.2</junit-version>

        <maven.compiler.source>25</maven.compiler.source>
        <maven.compiler.target>25</maven.compiler.target>
        <maven.compiler.release>25</maven.compiler.release>

        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
    </properties>

    <dependencyManagement>
        <dependencies>
            <dependency>
                <groupId>org.junit</groupId>
                <artifactId>junit-bom</artifactId>
                <version>${junit-version}</version>
                <type>pom</type>
                <scope>import</scope>
            </dependency>
            <dependency>
                <groupId>info.picocli</groupId>
                <artifactId>picocli</artifactId>
                <version>${picocli-version}</version>
            </dependency>
            <dependency>
                <groupId>org.snakeyaml</groupId>
                <artifactId>snakeyaml-engine</artifactId>
                <version>${snakeyaml-engine-version}</version>
            </dependency>
        </dependencies>
    </dependencyManagement>

    <build>
        <plugins>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-compiler-plugin</artifactId>
                <version>3.14.0</version>
            </plugin>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-surefire-plugin</artifactId>
                <version>3.5.4</version>
                <configuration>
                    <argLine>
                        @{argLine}
                        -Duser.timezone=UTC
                        --add-opens java.base/java.util=ALL-UNNAMED
                        --add-opens java.base/java.lang=ALL-UNNAMED
                    </argLine>
                </configuration>
            </plugin>
            <plugin>
                <groupId>com.diffplug.spotless</groupId>
                <artifactId>spotless-maven-plugin</artifactId>
                <version>3.2.1</version>
                <configuration>
                    <java>
                        <googleJavaFormat>
                            <version>1.27.0</version>
                            <style>GOOGLE</style>
                        </googleJavaFormat>
                        <importOrder>
                            <order>\#,</order>
                        </importOrder>
                        <removeUnusedImports>
                            <engine>cleanthat-javaparser-unnecessaryimport</engine>
                        </removeUnusedImports>
                    </java>
                </configuration>
                <executions>
                    <execution>
                        <id>spotless-check</id>
                        <phase>validate</phase>
                        <goals>
                            <goal>check</goal>
                        </goals>
                    </execution>
                </executions>
            </plugin>
            <plugin>
                <groupId>org.jacoco</groupId>
                <artifactId>jacoco-maven-plugin</artifactId>
                <version>0.8.14</version>
                <executions>
                    <execution>
                        <goals>
                            <goal>prepare-agent</goal>
                        </goals>
                    </execution>
                    <execution>
                        <id>report</id>
                        <phase>test</phase>
                        <goals>
                            <goal>report</goal>
                        </goals>
                    </execution>
                    <execution>
                        <id>coverage-check</id>
                        <phase>verify</phase>
                        <goals>
                            <goal>check</goal>
                        </goals>
                        <configuration>
                            <rules>
                                <rule>
                                    <element>BUNDLE</element>
                                    <!--
                                        Ratchet: each minimum sits just under the weakest module's
                                        actual for that counter (line/branch/method bound by
                                        sail-infra ~0.54/0.46/0.73; class bound by sail-harness 0.89)
                                        so the current bar is locked in and any regression fails the
                                        build. Raise these as coverage climbs toward 100%.
                                    -->
                                    <limits>
                                        <limit>
                                            <counter>LINE</counter>
                                            <value>COVEREDRATIO</value>
                                            <minimum>0.53</minimum>
                                        </limit>
                                        <limit>
                                            <counter>METHOD</counter>
                                            <value>COVEREDRATIO</value>
                                            <minimum>0.72</minimum>
                                        </limit>
                                        <limit>
                                            <counter>BRANCH</counter>
                                            <value>COVEREDRATIO</value>
                                            <minimum>0.45</minimum>
                                        </limit>
                                        <limit>
                                            <counter>CLASS</counter>
                                            <value>COVEREDRATIO</value>
                                            <minimum>0.88</minimum>
                                        </limit>
                                    </limits>
                                </rule>
                                <rule>
                                    <element>CLASS</element>
                                    <includes>
                                        <include>ai.singlr.sail.api.*</include>
                                    </includes>
                                    <!--
                                        Streaming I/O classes carry OS-level error branches
                                        (NIO accept failures, half-closed sockets, slow-client
                                        write timeouts) that can only be exercised by injecting
                                        kernel-level faults. They're covered end-to-end by
                                        SseHandlerTest and LocalApiSocketTest with real
                                        sockets; full line coverage of every defensive catch is
                                        not achievable without fault injection infrastructure.
                                        Tracked separately below with relaxed thresholds.
                                    -->
                                    <excludes>
                                        <exclude>ai.singlr.sail.api.SseHandler</exclude>
                                        <exclude>ai.singlr.sail.api.SseHandler.StreamSubscriber</exclude>
                                        <exclude>ai.singlr.sail.api.LocalApiSocket</exclude>
                                        <exclude>ai.singlr.sail.api.SailApiOperations</exclude>
                                        <exclude>ai.singlr.sail.api.SailApiClient</exclude>
                                        <exclude>ai.singlr.sail.api.ReviewPipelineController</exclude>
                                        <exclude>ai.singlr.sail.api.AgentLogStreamer</exclude>
                                        <exclude>ai.singlr.sail.api.EventStreamClient</exclude>
                                        <exclude>ai.singlr.sail.api.EventStreamClient.StopReadingException</exclude>
                                    </excludes>
                                    <limits>
                                        <limit>
                                            <counter>LINE</counter>
                                            <value>COVEREDRATIO</value>
                                            <minimum>1.0</minimum>
                                        </limit>
                                        <limit>
                                            <counter>METHOD</counter>
                                            <value>COVEREDRATIO</value>
                                            <minimum>1.0</minimum>
                                        </limit>
                                    </limits>
                                </rule>
                                <rule>
                                    <element>CLASS</element>
                                    <includes>
                                        <include>ai.singlr.sail.api.SseHandler</include>
                                        <include>ai.singlr.sail.api.SseHandler.StreamSubscriber</include>
                                        <include>ai.singlr.sail.api.LocalApiSocket</include>
                                    </includes>
                                    <limits>
                                        <limit>
                                            <counter>LINE</counter>
                                            <value>COVEREDRATIO</value>
                                            <minimum>0.7</minimum>
                                        </limit>
                                        <limit>
                                            <counter>METHOD</counter>
                                            <value>COVEREDRATIO</value>
                                            <minimum>0.7</minimum>
                                        </limit>
                                    </limits>
                                </rule>
                                <rule>
                                    <element>CLASS</element>
                                    <includes>
                                        <include>ai.singlr.sail.api.EventStreamClient</include>
                                    </includes>
                                    <!--
                                        EventStreamClient runs a virtual-thread SSE reader that
                                        carries two defensive catch blocks: a generic 'stream
                                        ended' handler (fires when the HTTP body throws while
                                        the watcher main loop is still alive) and a silent
                                        close() that swallows IOException from the underlying
                                        line stream. Both fire only on injected I/O failures
                                        that the testcontainer harness doesn't reproduce. The
                                        happy path, the 4xx response branch, the project filter,
                                        the close() handshake, and the per-line parser are all
                                        exercised by EventStreamClientTest.
                                    -->
                                    <limits>
                                        <limit>
                                            <counter>LINE</counter>
                                            <value>COVEREDRATIO</value>
                                            <minimum>0.85</minimum>
                                        </limit>
                                        <limit>
                                            <counter>METHOD</counter>
                                            <value>COVEREDRATIO</value>
                                            <minimum>0.85</minimum>
                                        </limit>
                                    </limits>
                                </rule>
                                <rule>
                                    <element>CLASS</element>
                                    <includes>
                                        <include>ai.singlr.sail.api.EventStreamClient.StopReadingException</include>
                                    </includes>
                                    <!--
                                        StopReadingException is a private control-flow sentinel
                                        thrown from inside the SSE reader lambda to break out of
                                        Stream.forEach. It carries no logic — just a no-op
                                        constructor — and is never directly tested. Coverage is
                                        deliberately not enforced; the constructor is exercised
                                        only when close() races with the reader.
                                    -->
                                    <limits>
                                        <limit>
                                            <counter>LINE</counter>
                                            <value>COVEREDRATIO</value>
                                            <minimum>0.0</minimum>
                                        </limit>
                                        <limit>
                                            <counter>METHOD</counter>
                                            <value>COVEREDRATIO</value>
                                            <minimum>0.0</minimum>
                                        </limit>
                                    </limits>
                                </rule>
                                <rule>
                                    <element>CLASS</element>
                                    <includes>
                                        <include>ai.singlr.sail.api.SailApiOperations</include>
                                    </includes>
                                    <!--
                                        SailApiOperations dispatch path includes lifecycle event
                                        publishers and review operations that depend on container
                                        state or database stores injected at server startup.
                                        Tested via router integration tests with FakeOperations;
                                        real operations tested where database is available.
                                    -->
                                    <limits>
                                        <limit>
                                            <counter>LINE</counter>
                                            <value>COVEREDRATIO</value>
                                            <minimum>0.80</minimum>
                                        </limit>
                                        <limit>
                                            <counter>METHOD</counter>
                                            <value>COVEREDRATIO</value>
                                            <minimum>0.78</minimum>
                                        </limit>
                                    </limits>
                                </rule>
                                <rule>
                                    <element>CLASS</element>
                                    <includes>
                                        <include>ai.singlr.sail.engine.GitSpecSync</include>
                                    </includes>
                                    <limits>
                                        <limit>
                                            <counter>LINE</counter>
                                            <value>COVEREDRATIO</value>
                                            <minimum>1.0</minimum>
                                        </limit>
                                        <limit>
                                            <counter>METHOD</counter>
                                            <value>COVEREDRATIO</value>
                                            <minimum>1.0</minimum>
                                        </limit>
                                    </limits>
                                </rule>
                                <rule>
                                    <element>CLASS</element>
                                    <includes>
                                        <include>ai.singlr.sail.commands.CliCommand</include>
                                    </includes>
                                    <limits>
                                        <limit>
                                            <counter>LINE</counter>
                                            <value>COVEREDRATIO</value>
                                            <minimum>1.0</minimum>
                                        </limit>
                                        <limit>
                                            <counter>METHOD</counter>
                                            <value>COVEREDRATIO</value>
                                            <minimum>1.0</minimum>
                                        </limit>
                                        <limit>
                                            <counter>BRANCH</counter>
                                            <value>COVEREDRATIO</value>
                                            <minimum>1.0</minimum>
                                        </limit>
                                    </limits>
                                </rule>
                                <rule>
                                    <element>CLASS</element>
                                    <includes>
                                        <include>ai.singlr.sail.commands.CliJson</include>
                                    </includes>
                                    <limits>
                                        <limit>
                                            <counter>LINE</counter>
                                            <value>COVEREDRATIO</value>
                                            <minimum>0.96</minimum>
                                        </limit>
                                        <limit>
                                            <counter>METHOD</counter>
                                            <value>COVEREDRATIO</value>
                                            <minimum>1.0</minimum>
                                        </limit>
                                        <limit>
                                            <counter>BRANCH</counter>
                                            <value>COVEREDRATIO</value>
                                            <minimum>0.97</minimum>
                                        </limit>
                                    </limits>
                                </rule>
                            </rules>
                        </configuration>
                    </execution>
                </executions>
            </plugin>
        </plugins>
    </build>
</project>
